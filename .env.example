# Path to existing image dataset (date folders YYYY.MM.DD)
DATA_DIR=./sample-data

# Final site output (Apache DocumentRoot)
OUTPUT_DIR=./dist

# Fresh builds are written here first, then atomically moved to OUTPUT_DIR
# STAGING_DIR=./dist.staging
ATOMIC_BUILD=1

# Optional ownership/modes applied before deploy (requires permission to chown)
# DEPLOY_USER=deploy
# DEPLOY_GROUP=www-data
# DEPLOY_DIR_MODE=755
# DEPLOY_FILE_MODE=644

# Hero slideshow: number of most recent images
FEATURED_COUNT=5

# Slideshow auto-advance interval in milliseconds
SLIDE_INTERVAL_MS=6000

# Thumbnail max width for grid cards (pixels)
THUMB_MAX_WIDTH=600

# Detail page display max width (0 = copy original format)
DISPLAY_MAX_WIDTH=2400

# Site metadata
SITE_URL=https://gallery.example.org
SITE_TITLE=OST Gallery

# Default site-wide license (shown in footer on every page)
SITE_LICENSE_SHORT=CC BY-NC-SA 3.0
SITE_LICENSE_NAME=Creative Commons Attribution-NonCommercial-ShareAlike 3.0 License
SITE_LICENSE_URL=https://creativecommons.org/licenses/by-nc-sa/3.0/
SITE_LICENSE_BADGE=by-nc-sa

# Optional append-only build log
# LOG_FILE=/var/log/ost-gallery-build.log
